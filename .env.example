# Yandex AI Studio Configuration
YANDEX_CLOUD_FOLDER_ID=your-folder-id
YANDEX_CLOUD_IAM_TOKEN=your-iam-token
YANDEX_AI_STUDIO_BASE_URL=https://llm.api.cloud.yandex.net

# Database Configuration
POSTGRES_DB=fever_routing
POSTGRES_USER=fever_user
POSTGRES_PASSWORD=secure_password_change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Application Configuration
SECRET_KEY=your-secret-key-change-me-in-production
DEBUG=false
ENVIRONMENT=production

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin_change_me

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Storage
EXPORTS_DIR=./data/exports
PDF_DIR=./data/exports/pdf

# Performance
MAX_WORKERS=4
WORKER_CONNECTIONS=1000

# LangGraph (лимит шагов; при GraphRecursionError можно поднять осторожно)
GRAPH_RECURSION_LIMIT=50
MAX_REQUESTS=1000
TIMEOUT=120

# AI Studio Agent IDs
INTAKE_AGENT_ID=YOUR_INTAKE_AGENT_ID
TRIAGE_AGENT_ID=YOUR_TRIAGE_AGENT_ID
QUESTION_AGENT_ID=YOUR_QUESTION_AGENT_ID
INFECTION_AGENT_ID=YOUR_INFECTION_AGENT_ID
IMMUNE_AGENT_ID=YOUR_IMMUNE_AGENT_ID
ONCOLOGY_AGENT_ID=YOUR_ONCOLOGY_AGENT_ID
RARE_DISEASE_AGENT_ID=YOUR_RARE_DISEASE_AGENT_ID
SYNTHESIS_AGENT_ID=YOUR_SYNTHESIS_AGENT_ID

# Model Configuration
MODEL_URI=gpt://YOUR_FOLDER_ID/qwen3-235b-a22b-fp8/latest
TEMPERATURE=0.7
MAX_TOKENS=4000

# Security (для ВМ: укажите URL фронта, с которого заходят пользователи)
# Пример для ВМ по IP: CORS_ORIGINS=http://192.168.1.100:3000
# Пример с доменом: CORS_ORIGINS=https://fever.example.com
CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]
ALLOWED_HOSTS=["localhost", "127.0.0.1", "yourdomain.com"]

# Деплой на ВМ: URL бэкенда для сборки фронта (пусто = relative, nginx проксирует /api/)
# FRONTEND_API_URL=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Session Configuration
SESSION_TIMEOUT_MINUTES=60
MAX_SESSIONS_PER_USER=10

# Cache Configuration
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE="0 2 * * *"

# Health Check Configuration
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=10

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL_SECONDS=30
WS_MAX_CONNECTIONS_PER_SESSION=5

# PDF Generation
PDF_TEMPLATE_DIR=./templates/pdf
PDF_FONT_DIR=./fonts
PDF_MAX_SIZE_MB=10

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Fever Routing System

# External Services (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
SLACK_WEBHOOK_URL=your-slack-webhook-url

# Analytics (optional)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
YANDEX_METRIKA_ID=XXXXXXXXX

# Development Settings
DEV_MODE=false
DEV_MOCK_AI_RESPONSES=false
DEV_ENABLE_PROFILING=false

# Testing Settings
TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db
TEST_REDIS_URL=redis://localhost:6379/1