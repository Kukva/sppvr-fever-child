# Шаблон для ВМ. При деплое через clean_and_deploy_vm.sh подставляется VM_HOST вместо VM_HOST_PLACEHOLDER.
# На ВМ вручную: cp env.vm.example .env && sed -i 's/VM_HOST_PLACEHOLDER/ваш.хост/g' .env
# Затем задайте YANDEX_CLOUD_FOLDER_ID, YANDEX_CLOUD_IAM_TOKEN, POSTGRES_PASSWORD.

# Origin фронта: HTTP с порта 3000 и HTTPS через Caddy на 443 (без порта в URL)
CORS_ORIGINS=http://VM_HOST_PLACEHOLDER:3000,https://VM_HOST_PLACEHOLDER,http://localhost:3000
ALLOWED_HOSTS=VM_HOST_PLACEHOLDER,localhost,127.0.0.1

# Фронт и бэкенд с одного хоста — пусто (nginx проксирует /api/)
FRONTEND_API_URL=
