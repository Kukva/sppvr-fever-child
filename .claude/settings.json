{
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",

      "Bash(docker *)",
      "Bash(docker-compose *)",

      "PowerShell(docker *)",
      "PowerShell(docker-compose *)",
      "PowerShell(cd *)",
      "PowerShell(Get-Content *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(New-Item *)",
      "PowerShell(Write-Host *)",
      "PowerShell(Start-Sleep *)",
      "PowerShell(Add-Type *)",

      "WebSearch(*)",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "PowerShell(Remove-Item -Recurse *)"
    ]
  }
}
